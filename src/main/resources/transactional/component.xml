<component name="transactional" displayName="Transactional" type="synapse/template">
    <subComponents>
        <component name="beginTransaction">
            <file>beginTransaction.xml</file>
            <displayName>Begin Transaction</displayName>
            <description>Begins a new Solace transaction.</description>
        </component>
        <component name="commit">
             <file>commit.xml</file>
             <displayName>Commit Transaction</displayName>
             <description>Commits the current Solace transaction, making all operations since the last beginTransaction permanent.</description>
        </component>
        <component name="rollback">
            <file>rollback.xml</file>
            <displayName>Rollback Transaction</displayName>
            <description>Rolls back the current Solace transaction, undoing all operations since the last beginTransaction.</description>
        </component>
    </subComponents>
</component>
