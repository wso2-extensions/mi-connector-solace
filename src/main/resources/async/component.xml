<component name="async" displayName="Asynchronous" type="synapse/template">
    <subComponents>
        <component name="publishMessage">
            <file>publishMessage.xml</file>
            <displayName>Publish Message</displayName>
            <description>Publishes a message to a Solace topic or queue (fire-and-forget).</description>
        </component>
        <component name="acknowledgeMessage">
            <file>acknowledgeMessage.xml</file>
            <displayName>Acknowledge Message</displayName>
            <description>Acknowledges a message received by the inbound endpoint so the broker can remove it from the queue.</description>
        </component>
        <component name="nackMessage">
            <file>nackMessage.xml</file>
            <displayName>Nack Message</displayName>
            <description>Negatively acknowledges a message. FAILED triggers redelivery; REJECTED routes to the Dead Message Queue.</description>
        </component>
    </subComponents>
</component>
