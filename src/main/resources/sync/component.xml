<component name="sync" displayName="Synchronous" type="synapse/template">
    <subComponents>
        <component name="sendRequest">
            <file>sendRequest.xml</file>
            <displayName>Send Request</displayName>
            <description>Sends a request message and waits for a response (synchronous request-reply).</description>
        </component>
        <component name="sendReply">
            <file>sendReply.xml</file>
            <displayName>Send Reply</displayName>
            <description>Sends a reply to an inbound request message using the reply-to destination from the message context. Pairs with Send Request.</description>
        </component>
    </subComponents>
</component>
